# Common defaults for all targets. Per-target sdkconfig is generated by build.sh
# into build_<target>/sdkconfig. Override anything via `idf.py menuconfig`.

# 4 MB flash, single app — plenty for an ESP-NOW-only firmware.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_SINGLE_APP=y

# Flipper/Furi runs at 1 kHz tick; not required here but harmless and keeps
# timing identical to the master if code is shared later.
CONFIG_FREERTOS_HZ=1000

CONFIG_LOG_DEFAULT_LEVEL_INFO=y
